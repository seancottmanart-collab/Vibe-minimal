<style>
:root {
  --ink:       #111010;
  --deep:      #1E1C1A;
  --body:      #3A3835;
  --muted:     #7A756F;
  --hairline:  #E2DDD7;
  --cream:     #F8F4EE;
  --warm:      #FDFAF6;
  --gold:      #B8862E;
  --gold-lt:   #E4C97E;
  --gold-bg:   #FAF4E6;
  --red:       #C0392B;
  --tag-green: #2D6A4F;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--warm);
  color: var(--body);
  font-family: 'Outfit', sans-serif;
  font-weight: 300;
  line-height: 1.7;
}

/* ─── MASTHEAD ─── */
.masthead {
  background: var(--ink);
  text-align: center;
  padding: 10px 5vw;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-lt);
}

nav {
  position: sticky; top: 0; z-index: 200;
  background: var(--warm);
  border-bottom: 1px solid var(--hairline);
  padding: 0 5vw;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  height: 62px;
  box-shadow: 0 1px 12px rgba(0,0,0,0.04);
}
.nav-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.55rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--ink);
  text-decoration: none;
  white-space: nowrap;
}
.nav-brand span { color: var(--gold); }
.nav-cats {
  display: flex; gap: 0; list-style: none; align-items: center;
}
.nav-cats li a {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  padding: 4px 14px;
  border-radius: 2px;
  transition: color .2s, background .2s;
  white-space: nowrap;
}
.nav-cats li a:hover { color: var(--ink); background: var(--cream); }
.nav-cta {
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--gold-lt);
  padding: 8px 16px;
  border-radius: 2px;
  text-decoration: none;
  white-space: nowrap;
  transition: background .2s;
}
.nav-cta:hover { background: var(--deep); }

/* ─── HERO ─── */
.hero {
  background: var(--ink);
  color: var(--cream);
  padding: 64px 5vw 56px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 60% 0%, rgba(184,134,46,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.hero-badge {
  display: inline-block;
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--gold);
  padding: 4px 14px;
  border-radius: 2px;
  margin-bottom: 22px;
  opacity: 0;
  animation: fadeUp .6s ease .1s forwards;
}
.hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.2rem, 6vw, 4rem);
  font-weight: 700;
  line-height: 1.15;
  color: #fff;
  max-width: 820px;
  margin: 0 auto 20px;
  opacity: 0;
  animation: fadeUp .7s ease .2s forwards;
}
.hero h1 em {
  font-style: italic;
  color: var(--gold-lt);
}
.hero-sub {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.6);
  max-width: 560px;
  margin: 0 auto 32px;
  line-height: 1.8;
  font-weight: 300;
  opacity: 0;
  animation: fadeUp .7s ease .35s forwards;
}
.hero-meta {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  opacity: 0;
  animation: fadeUp .7s ease .45s forwards;
}
.hero-meta strong { color: rgba(255,255,255,0.65); font-weight: 400; }
.hero-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  margin: 28px auto 0;
  opacity: 0;
  animation: fadeUp .6s ease .55s forwards;
}

/* ─── FTC DISCLOSURE ─── */
.disclosure {
  max-width: 860px; margin: 0 auto;
  padding: 12px 5vw;
  background: var(--gold-bg);
  border-left: 3px solid var(--gold);
  font-size: 0.72rem;
  color: var(--muted);
  line-height: 1.6;
}

/* ─── CONTENT WRAPPER ─── */
.content {
  max-width: 860px;
  margin: 0 auto;
  padding: 48px 5vw 80px;
}

/* ─── ARTICLE INTRO ─── */
.article-intro {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.08rem;
  line-height: 1.95;
  color: var(--deep);
  margin-bottom: 50px;
  padding-bottom: 40px;
  border-bottom: 1px solid var(--hairline);
}
.article-intro p + p { margin-top: 1em; }

/* ─── SECTION HEADER ─── */
.section-label {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 32px;
}
.section-label::before, .section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--hairline);
}
.section-label span {
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}

/* ─── PRODUCT CARDS ─── */
.products-grid {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.product-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0;
  border-bottom: 1px solid var(--hairline);
  padding: 36px 0;
  opacity: 0;
  transform: translateY(16px);
  animation: fadeUp .5s ease forwards;
  text-decoration: none;
  color: inherit;
  transition: background .15s;
}
.product-card:nth-child(1) { animation-delay: .05s; }
.product-card:nth-child(2) { animation-delay: .1s; }
.product-card:nth-child(3) { animation-delay: .15s; }
.product-card:nth-child(4) { animation-delay: .2s; }
.product-card:nth-child(5) { animation-delay: .25s; }
.product-card:nth-child(6) { animation-delay: .3s; }
.product-card:nth-child(7) { animation-delay: .35s; }
.product-card:nth-child(8) { animation-delay: .4s; }
.product-card:nth-child(9) { animation-delay: .45s; }
.product-card:nth-child(10){ animation-delay: .5s; }

.product-card:hover .product-img-wrap { transform: scale(1.02); }
.product-card:hover .shop-btn { background: var(--ink); color: var(--gold-lt); }

.product-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3.5rem;
  font-weight: 600;
  color: var(--hairline);
  line-height: 1;
  padding-right: 28px;
  padding-top: 4px;
  min-width: 64px;
  text-align: right;
  user-select: none;
}

.product-body {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 28px;
  align-items: start;
}

.product-img-wrap {
  width: 180px;
  aspect-ratio: 1 / 1;
  border-radius: 4px;
  overflow: hidden;
  background: var(--cream);
  transition: transform .3s ease;
  flex-shrink: 0;
}
.product-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

.product-info { flex: 1; }

.product-tags {
  display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px;
}
.tag {
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 2px 9px;
  border-radius: 2px;
  font-weight: 500;
}
.tag-home    { background: #EEF4FF; color: #3B5BA9; }
.tag-kitchen { background: #FFF0EC; color: #B84A2B; }
.tag-style   { background: #F0FAF4; color: var(--tag-green); }
.tag-self    { background: #FCF0FF; color: #7B3FA0; }
.tag-tech    { background: #F0F9FF; color: #1B6FA8; }
.tag-deal    { background: var(--gold-bg); color: var(--gold); border: 1px solid var(--gold-lt); }

.product-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.45rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 10px;
}
.product-title em { font-style: italic; color: var(--gold); }

.product-desc {
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--muted);
  margin-bottom: 18px;
}

.product-footer {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.product-price {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: -0.01em;
}
.price-was {
  font-size: 0.8rem;
  color: var(--muted);
  text-decoration: line-through;
  font-weight: 300;
}
.shop-btn {
  display: inline-block;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 500;
  background: var(--cream);
  color: var(--ink);
  border: 1px solid var(--hairline);
  padding: 9px 20px;
  border-radius: 2px;
  text-decoration: none;
  transition: background .2s, color .2s, border-color .2s;
  cursor: pointer;
}
.shop-btn:hover { background: var(--ink); color: var(--gold-lt); border-color: var(--ink); }
.stars {
  font-size: 0.75rem;
  color: var(--gold);
  letter-spacing: 1px;
}
.star-count { color: var(--muted); font-size: 0.72rem; margin-left: 3px; }

/* ─── CATEGORY FILTER BAR ─── */
.filter-bar {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 40px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--hairline);
}
.filter-btn {
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 500;
  background: none;
  border: 1px solid var(--hairline);
  color: var(--muted);
  padding: 7px 16px;
  border-radius: 2px;
  cursor: pointer;
  transition: all .2s;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--ink);
  color: var(--gold-lt);
  border-color: var(--ink);
}

/* ─── NEWSLETTER ─── */
.newsletter-block {
  background: var(--ink);
  border-radius: 4px;
  padding: 48px 40px;
  text-align: center;
  margin: 60px 0 0;
  position: relative;
  overflow: hidden;
}
.newsletter-block::before {
  content: '';
  position: absolute; top: -40px; right: -40px;
  width: 200px; height: 200px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(184,134,46,0.2), transparent 70%);
}
.newsletter-block h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
}
.newsletter-block p {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 24px;
}
.newsletter-form {
  display: flex;
  gap: 8px;
  max-width: 420px;
  margin: 0 auto;
}
.newsletter-form input {
  flex: 1;
  padding: 11px 16px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 2px;
  color: #fff;
  font-size: 0.85rem;
  font-family: 'Outfit', sans-serif;
  outline: none;
  transition: border-color .2s;
}
.newsletter-form input::placeholder { color: rgba(255,255,255,0.3); }
.newsletter-form input:focus { border-color: var(--gold); }
.newsletter-form button {
  padding: 11px 22px;
  background: var(--gold);
  color: var(--ink);
  border: none;
  border-radius: 2px;
  font-family: 'Outfit', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  transition: background .2s;
}
.newsletter-form button:hover { background: var(--gold-lt); }

/* ─── FOOTER ─── */
footer {
  background: var(--deep);
  color: rgba(255,255,255,0.4);
  text-align: center;
  padding: 36px 5vw;
  font-size: 0.72rem;
  line-height: 1.8;
  letter-spacing: 0.04em;
}
footer a { color: rgba(255,255,255,0.55); text-decoration: none; }
footer a:hover { color: var(--gold-lt); }
.footer-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* ─── HIDE / SHOW FILTER ─── */
.product-card.hidden { display: none; }

/* ─── RESPONSIVE ─── */
@media (max-width: 640px) {
  .product-body { grid-template-columns: 1fr; }
  .product-num { font-size: 2.2rem; min-width: auto; padding-right: 16px; }
  .product-img-wrap { width: 100%; }
  .nav-cats { display: none; }
  .newsletter-form { flex-direction: column; }
}
</style>

